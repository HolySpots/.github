{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/admin/**",
              "components/core/**",
              "components/mobile/**",
              "ui_kits/admin/**",
              "ui_kits/mobile/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Roboto))/i]",
        "message": "Font not provided by the design system. Available: Roboto."
      },
      {
        "selector": "JSXOpeningElement[name.name='AdminMenu'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|selected|onSelect|userName|assets|key|ref|className|style|children)$/]",
        "message": "<AdminMenu> doesn't accept that prop. Declared props: items, selected, onSelect, userName, assets."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppToolbar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|transparent|onBack|actions|assets|key|ref|className|style|children)$/]",
        "message": "<AppToolbar> doesn't accept that prop. Declared props: title, transparent, onBack, actions, assets."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|fullWidth|fixedWidth|children|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, fullWidth, fixedWidth, children, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|save|secondary|cancel|delete)$/]",
        "message": "<Button> variant must be one of 'primary' | 'save' | 'secondary' | 'cancel' | 'delete'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md)$/]",
        "message": "<Button> size must be one of 'lg' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckboxChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|square|children|key|ref|className|style|children)$/]",
        "message": "<CheckboxChip> doesn't accept that prop. Declared props: checked, onChange, square, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckInBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:checkedIn|onCheckIn|onDelete|assets|key|ref|className|style|children)$/]",
        "message": "<CheckInBar> doesn't accept that prop. Declared props: checkedIn, onCheckIn, onDelete, assets."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTable'] > JSXAttribute > JSXIdentifier[name!=/^(?:columns|rows|onRowClick|key|ref|className|style|children)$/]",
        "message": "<DataTable> doesn't accept that prop. Declared props: columns, rows, onRowClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|filled|onClick|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, label, filled, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|error|serif|multiline|variant|placeholder|value|onChange|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, error, serif, multiline, variant, placeholder, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:admin|filter|login)$/]",
        "message": "<Input> variant must be one of 'admin' | 'filter' | 'login'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pagination'] > JSXAttribute > JSXIdentifier[name!=/^(?:pages|active|onChange|key|ref|className|style|children)$/]",
        "message": "<Pagination> doesn't accept that prop. Declared props: pages, active, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='RegionCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:photo|name|spotCount|height|onClick|assets|key|ref|className|style|children)$/]",
        "message": "<RegionCard> doesn't accept that prop. Declared props: photo, name, spotCount, height, onClick, assets."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReviewCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|text|date|photos|assets|key|ref|className|style|children)$/]",
        "message": "<ReviewCard> doesn't accept that prop. Declared props: title, text, date, photos, assets."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|filled|value|onChange|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: options, filled, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='SmileRating'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|assets|key|ref|className|style|children)$/]",
        "message": "<SmileRating> doesn't accept that prop. Declared props: value, onChange, assets."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpotListItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:photo|name|info|status|checkedIn|onClick|assets|key|ref|className|style|children)$/]",
        "message": "<SpotListItem> doesn't accept that prop. Declared props: photo, name, info, status, checkedIn, onClick, assets."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpotListItem'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:open|closed)$/]",
        "message": "<SpotListItem> status must be one of 'open' | 'closed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|key|ref|className|style|children)$/]",
        "message": "<StatusLabel> doesn't accept that prop. Declared props: status."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusLabel'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:open|closed)$/]",
        "message": "<StatusLabel> status must be one of 'open' | 'closed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|active|onChange|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: tabs, active, onChange."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
